{
  "version": 1,
  "id": "paper-light",
  "name": "Paper Light",
  "type": "light",
  "author": "Cate",
  "description": "Soft paper-white surfaces with an ink-blue accent.",
  "bootBackground": "#f3f1ec",
  "app": {
    "surface-0": "#e9e6df",
    "surface-1": "#f0ede7",
    "surface-2": "#f5f3ee",
    "surface-3": "#eceae3",
    "surface-4": "#e6e3db",
    "surface-5": "#dedbd2",
    "surface-6": "#d6d2c8",
    "titlebar-bg": "#e9e6df",
    "canvas-bg": "#f5f3ee",
    "canvas-bg-alt": "#faf8f4",
    "grid-dot": "rgba(40, 38, 33, 0.10)",
    "grid-line": "rgba(40, 38, 33, 0.05)",
    "border-subtle": "rgba(40, 38, 33, 0.12)",
    "border-strong": "rgba(40, 38, 33, 0.24)",
    "border-focus": "#2f6fb0",
    "text-primary": "#23201a",
    "text-secondary": "#46413a",
    "text-muted": "#6f6a60",
    "text-inverse": "#f5f3ee",
    "focus-blue": "#2f6fb0",
    "activity-green": "#4a8f3a",
    "activity-orange": "#c4601a",
    "shadow-node": "rgba(40, 38, 33, 0.16)",
    "shadow-node-focused": "rgba(47, 111, 176, 0.35)",
    "node-bg-active": "#f5f3ee",
    "node-dim-overlay": "rgba(40, 38, 33, 0.08)",
    "scrollbar-thumb": "rgba(40, 38, 33, 0.22)",
    "scrollbar-thumb-hover": "rgba(40, 38, 33, 0.38)",
    "surface-hover": "rgba(40, 38, 33, 0.06)",
    "surface-hover-strong": "rgba(40, 38, 33, 0.12)",
    "git-added": "#4a8f3a",
    "git-modified": "#b07d00",
    "git-deleted": "#c0392e",
    "git-untracked": "#2f6fb0",
    "git-renamed": "#7a5aa8",
    "panel-terminal": "#2f8f3f",
    "panel-browser": "#2b5fbf",
    "panel-editor": "#c46900",
    "panel-git": "#c0382e",
    "panel-fileExplorer": "#2e8fbf",
    "panel-projectList": "#a07a00",
    "panel-canvas": "#7d3ab8",
    "agent-rgb": "47 111 176",
    "agent-light-rgb": "30 70 130"
  },
  "terminal": {
    "background": "#f3f1ec",
    "foreground": "#23201a",
    "cursor": "#2f6fb0",
    "cursorAccent": "#f3f1ec",
    "selectionBackground": "#d6d2c8",
    "selectionForeground": "#23201a",
    "black": "#23201a",
    "red": "#c0392e",
    "green": "#4a8f3a",
    "yellow": "#b07d00",
    "blue": "#2f6fb0",
    "magenta": "#9b4a7a",
    "cyan": "#2e8f8f",
    "white": "#8a8478",
    "brightBlack": "#6f6a60",
    "brightRed": "#d24a3a",
    "brightGreen": "#5aa348",
    "brightYellow": "#c89a1f",
    "brightBlue": "#3f80c4",
    "brightMagenta": "#b05a8a",
    "brightCyan": "#3aa0a0",
    "brightWhite": "#23201a"
  },
  "editor": {
    "base": "vs",
    "colors": {
      "editor.background": "#f3f1ec",
      "editor.foreground": "#23201a",
      "editorGutter.background": "#f3f1ec",
      "minimap.background": "#f3f1ec",
      "editorLineNumber.foreground": "#9b9488",
      "editor.lineHighlightBackground": "#eceae3",
      "editor.selectionBackground": "#d6d2c8",
      "editorCursor.foreground": "#2f6fb0"
    },
    "tokens": [
      { "token": "comment", "foreground": "8a8478", "fontStyle": "italic" },
      { "token": "keyword", "foreground": "9b4a7a" },
      { "token": "storage", "foreground": "9b4a7a" },
      { "token": "string", "foreground": "4a8f3a" },
      { "token": "constant.numeric", "foreground": "c4601a" },
      { "token": "variable", "foreground": "23201a" },
      { "token": "entity.name.function", "foreground": "2f6fb0" },
      { "token": "type", "foreground": "b07d00" },
      { "token": "entity.name.tag", "foreground": "2f6fb0" },
      { "token": "regexp", "foreground": "c0392e" },
      { "token": "invalid", "foreground": "c0392e" }
    ]
  }
}
