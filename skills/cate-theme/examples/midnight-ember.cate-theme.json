{
  "version": 1,
  "id": "midnight-ember",
  "name": "Midnight Ember",
  "type": "dark",
  "author": "Cate",
  "description": "Warm charcoal surfaces with an ember-orange accent.",
  "bootBackground": "#1a1714",
  "app": {
    "surface-0": "#1a1714",
    "surface-1": "#221d18",
    "surface-2": "#2a241e",
    "surface-3": "#322a23",
    "surface-4": "#3a3128",
    "surface-5": "#43382e",
    "surface-6": "#4c4034",
    "titlebar-bg": "#221d18",
    "canvas-bg": "#141110",
    "canvas-bg-alt": "#1a1714",
    "grid-dot": "rgba(231, 221, 208, 0.07)",
    "grid-line": "rgba(231, 221, 208, 0.03)",
    "border-subtle": "rgba(231, 221, 208, 0.06)",
    "border-strong": "rgba(231, 221, 208, 0.12)",
    "border-focus": "#e0683c",
    "text-primary": "#e7ddd0",
    "text-secondary": "#c2b6a6",
    "text-muted": "#9b9186",
    "text-inverse": "#1a1714",
    "focus-blue": "#e0683c",
    "activity-green": "#8fa86a",
    "activity-orange": "#d9a441",
    "shadow-node": "rgba(0, 0, 0, 0.5)",
    "shadow-node-focused": "rgba(224, 104, 60, 0.35)",
    "node-bg-active": "#1f1b16",
    "node-dim-overlay": "rgba(0, 0, 0, 0.2)",
    "scrollbar-thumb": "rgba(231, 221, 208, 0.15)",
    "scrollbar-thumb-hover": "rgba(231, 221, 208, 0.25)",
    "surface-hover": "rgba(231, 221, 208, 0.06)",
    "surface-hover-strong": "rgba(231, 221, 208, 0.12)",
    "git-added": "#8fa86a",
    "git-modified": "#d9a441",
    "git-deleted": "#e0683c",
    "git-untracked": "#5f90c4",
    "git-renamed": "#b06aa0",
    "panel-terminal": "#6a8a4a",
    "panel-browser": "#5f82b0",
    "panel-editor": "#c47a4a",
    "panel-canvas": "#9579a8",
    "agent-rgb": "224 104 60",
    "agent-light-rgb": "240 133 90"
  },
  "terminal": {
    "background": "#1a1714",
    "foreground": "#e7ddd0",
    "cursor": "#e0683c",
    "selectionBackground": "#3a2f26",
    "black": "#1a1714",
    "red": "#e0683c",
    "green": "#8fa86a",
    "yellow": "#d9a441",
    "blue": "#5f90c4",
    "magenta": "#b06aa0",
    "cyan": "#5fa8a8",
    "white": "#d8cdbf",
    "brightBlack": "#6b6258",
    "brightRed": "#f0855a",
    "brightGreen": "#a6c47f",
    "brightYellow": "#e8bd6a",
    "brightBlue": "#7aa8d6",
    "brightMagenta": "#c884b8",
    "brightCyan": "#7cc0c0",
    "brightWhite": "#f4ece1"
  },
  "editor": {
    "base": "vs-dark",
    "colors": {
      "editor.background": "#1a1714",
      "editor.foreground": "#e7ddd0",
      "editorGutter.background": "#1a1714",
      "minimap.background": "#1a1714",
      "editorLineNumber.foreground": "#6b6258",
      "editor.selectionBackground": "#3a2f26",
      "editorCursor.foreground": "#e0683c"
    },
    "tokens": [
      { "token": "comment", "foreground": "6b6258", "fontStyle": "italic" },
      { "token": "keyword", "foreground": "e0683c" },
      { "token": "storage", "foreground": "e0683c" },
      { "token": "string", "foreground": "8fa86a" },
      { "token": "constant.numeric", "foreground": "d9a441" },
      { "token": "variable", "foreground": "e7ddd0" },
      { "token": "entity.name.function", "foreground": "b06aa0" },
      { "token": "type", "foreground": "5f90c4" },
      { "token": "entity.name.tag", "foreground": "e0683c" },
      { "token": "regexp", "foreground": "5fa8a8" },
      { "token": "invalid", "foreground": "f0855a" }
    ]
  }
}
